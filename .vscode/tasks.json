{
    "version": "2.0.0",
    "inputs": [],
    "tasks": [
        {
            "label": "Compile VS Code Extension",
            "type": "shell",
            "command": "npm",
            "args": [
                "run",
                "compile"
            ],
            "problemMatcher": [
                "$tsc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/SpecForge.AI.slnx",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile",
            "dependsOn": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "type": "shell",
            "label": "build inc version",
            "command": "dotnet build ${workspaceFolder}/SpecForge.AI.slnx",
            "problemMatcher": [
                "$msCompile"
            ],
            "dependsOn": [
                "Increase version"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Increase version",
            "command": "dotnet",
            "type": "shell",
            "args": [
                "tool",
                "run",
                "versionbumper"
            ],
            "group": "none",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build bundle",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "cd '${workspaceFolder}' && npm run compile && cd '../ai-skills-shared' && dotnet build ai-skills-shared.slnx"
            ],
            "problemMatcher": [
                "$tsc",
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        // {
        //     "label": "Crear nuevo tag",
        //     "type": "shell",
        //     "command": "${workspaceFolder}/terraform/scripts/create_newtag.sh",
