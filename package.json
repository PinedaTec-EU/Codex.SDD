{
  "name": "specforge-ai",
  "displayName": "SpecForge.AI",
  "description": "Minimal VS Code extension for exploring SpecForge.AI user stories.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:specForge.userStories",
    "onCommand:specForge.refreshUserStories",
    "onCommand:specForge.createUserStory",
    "onCommand:specForge.importUserStory",
    "onCommand:specForge.initializeRepoPrompts",
    "onCommand:specForge.openPromptTemplates",
    "onCommand:specForge.openWorkflowView",
    "onCommand:specForge.openMainArtifact",
    "onCommand:specForge.continuePhase",
    "onCommand:specForge.approveCurrentPhase",
    "onCommand:specForge.requestRegression",
    "onCommand:specForge.restartUserStoryFromSource",
    "onCommand:specForge.deleteUserStory",
    "onCommand:specForge.showUserStoryDetails",
    "onCommand:specForge.showOutput"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "specForge",
          "title": "SpecForge.AI",
          "icon": "media/specforge.svg"
        }
      ]
    },
    "views": {
      "specForge": [
        {
          "id": "specForge.userStories",
          "name": "User Stories",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "specForge.refreshUserStories",
        "title": "Refresh User Stories"
      },
      {
        "command": "specForge.createUserStory",
        "title": "Create User Story"
      },
      {
        "command": "specForge.importUserStory",
        "title": "Import User Story"
      },
      {
        "command": "specForge.initializeRepoPrompts",
        "title": "Initialize Repo Prompts"
      },
      {
        "command": "specForge.openPromptTemplates",
        "title": "Open Prompt Templates"
      },
      {
        "command": "specForge.openWorkflowView",
        "title": "Open Workflow View"
      },
      {
        "command": "specForge.openMainArtifact",
        "title": "Open Main Artifact"
      },
      {
        "command": "specForge.continuePhase",
        "title": "Continue Phase"
      },
      {
        "command": "specForge.approveCurrentPhase",
        "title": "Approve Current Phase"
      },
      {
        "command": "specForge.requestRegression",
        "title": "Request Regression"
      },
      {
        "command": "specForge.restartUserStoryFromSource",
        "title": "Restart User Story From Source"
      },
      {
        "command": "specForge.deleteUserStory",
        "title": "Delete User Story"
      },
      {
        "command": "specForge.showUserStoryDetails",
        "title": "Show User Story Details"
      },
      {
        "command": "specForge.showOutput",
        "title": "Show SpecForge Output"
      }
    ],
    "configuration": {
      "title": "SpecForge.AI",
      "properties": {
        "specForge.execution.provider": {
          "type": "string",
          "default": "deterministic",
          "enum": [
            "deterministic",
            "openai-compatible"
          ],
          "description": "Phase execution provider used by the local MCP backend."
        },
        "specForge.execution.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for the OpenAI-compatible provider."
        },
        "specForge.execution.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key passed to the OpenAI-compatible provider."
        },
        "specForge.execution.model": {
          "type": "string",
          "default": "",
          "description": "Model name used by the OpenAI-compatible provider."
        },
        "specForge.execution.clarificationTolerance": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "strict",
            "balanced",
            "inferential"
          ],
          "description": "How demanding clarification should be before the workflow advances to refinement. This also adjusts the temperature sent for the clarification phase."
        },
        "specForge.execution.reviewTolerance": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "strict",
            "balanced",
            "inferential"
          ],
          "description": "How demanding the review phase should be when assessing findings and pass/fail readiness. This also adjusts the temperature sent for the review phase."
        },
        "specForge.ui.enableWatcher": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the explorer and workflow view automatically when .specs files change."
        },
        "specForge.ui.notifyOnAttention": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when a user story becomes waiting-user, blocked, or completed."
        },
        "specForge.features.enableContextSuggestions": {
          "type": "boolean",
          "default": true,
          "description": "Suggest repository context files during clarification using local heuristics and repo neighborhood rules."
        },
        "specForge.features.requireApprovalBranchAcceptance": {
          "type": "boolean",
          "default": false,
          "description": "Require explicit acceptance of the proposed base branch in the workflow detail before approving refinement."
        },
        "specForge.features.autoPlayEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Automatically resume workflow playback after manual actions such as approving refinement when the next phase can continue."
        },
        "specForge.features.destructiveRewindEnabled": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, rewind and regress delete later derived artifacts and branch metadata. When disabled, both only move the workflow state back."
        }
      }
    },
    "menus": {}
  },
  "scripts": {
    "compile": "node node_modules/typescript/lib/tsc.js -p ./",
    "watch": "node node_modules/typescript/lib/tsc.js -watch -p ./",
    "compile:tests": "node node_modules/typescript/lib/tsc.js -p tsconfig.tests.json",
    "test:ts": "npm run compile:tests && node --test dist-tests/tests-ts/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "typescript": "^5.8.3"
  }
}
